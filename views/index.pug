extends layout

block content
  .dashboard
    header.site-header
      .header-inner
        .logo
          span.logo-icon 📈
          span.logo-text StockVision
        .header-right
          .market-status
            .status-dot
            span 市場 開場中
          .clock#clock

    main.main-area

      .kpi-row
        .kpi-card
          .kpi-label ポートフォリオ総額
          .kpi-value#total-val ¥3,842,500
          .kpi-sub.up ▲ +2.34% 今日
        .kpi-card
          .kpi-label 本日損益
          .kpi-value.up#daily-pnl +¥88,200
          .kpi-sub.up ▲ +2.34%
        .kpi-card
          .kpi-label 日経平均
          .kpi-value#nikkei 38,542.16
          .kpi-sub.up ▲ +0.87%
        .kpi-card
          .kpi-label 保有銘柄数
          .kpi-value 12
          .kpi-sub.flat ─ 変動なし

      .chart-row
        .chart-card
          .card-header
            .card-title
              span#sel-name トヨタ自動車 (7203)
              span.price-badge#sel-price ¥3,142
              span.chg-badge.up#sel-chg ▲ +1.24%
            .period-btns
              button.period-btn.active(data-period="1D") 1日
              button.period-btn(data-period="1W") 1週
              button.period-btn(data-period="1M") 1ヶ月
              button.period-btn(data-period="3M") 3ヶ月
              button.period-btn(data-period="1Y") 1年
          .chart-wrap
            canvas#mainChart

        .watchlist-card
          .card-header
            h2.card-title ウォッチリスト
          #watchlist-items

      .bottom-row
        .portfolio-card
          .card-header
            h2.card-title ポートフォリオ構成
          .donut-wrap
            canvas#donutChart(width="180" height="180")
            .donut-center
              .dl ポートフォリオ
              .dv ¥3.84M
          #portfolio-legend

        .news-card
          .card-header
            h2.card-title マーケットニュース
            span.live-badge LIVE
          #news-list

  script(src="/javascripts/dashboard.js")
