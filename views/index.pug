extends layout

block content
  .dashboard
    header.site-header
      .header-inner
        .logo
          span.logo-text Stock Manager
        .header-right
          button.btn-add(onclick="openModal()") + 新規銘柄を追加

    main.main-area
      .kpi-row
        .kpi-card
          .kpi-label ポートフォリオ総額
          .kpi-value#total-val ¥0
        .kpi-card
          .kpi-label 登録銘柄数
          .kpi-value#total-count 0

      .table-card
        table.stock-table
          thead
            tr
              th コード
              th 銘柄名
              th 現在値 (¥)
              th 保有株数
              th 評価額 (¥)
              th 操作
          tbody#stock-tbody
            // Generated by JS

  // モーダル (初期は非表示)
  .modal-backdrop#modal(style="display: none;")
    .modal-box
      .modal-header
        span.modal-title#modal-title 銘柄の追加
        button.modal-close(onclick="closeModal()") ×
      .modal-body
        .form-group
          label 証券コード
          input.edit-input#inp-code(type="text" placeholder="例: 7203" maxlength="6")
        .form-group
          label 銘柄名
          input.edit-input#inp-name(type="text" placeholder="例: トヨタ自動車")
        .form-group
          label 現在値 (¥)
          input.edit-input.num#inp-price(type="number" min="0")
        .form-group
          label 保有株数
          input.edit-input.num#inp-shares(type="number" min="1")
      .modal-footer
        button.btn-cancel(onclick="closeModal()") キャンセル
        button.btn-save(onclick="saveStock()") 保存

  script(src="/javascripts/dashboard.js")
